# EasySlides 环境变量示例
# 本地个人使用：什么都不用设，全部默认值即可（DEBUG 开、自动登录开）。
# 公网部署：至少设置前四项。

# Django 密钥（公网部署必须改，生成方式：
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"）
# DJANGO_SECRET_KEY=

# 调试模式：1 开 / 0 关（默认 1）
# DJANGO_DEBUG=0

# 允许的主机名，逗号分隔（默认 localhost,127.0.0.1）
# DJANGO_ALLOWED_HOSTS=slides.example.com

# CSRF 信任来源，逗号分隔（默认 https://localhost）
# CSRF_TRUSTED_ORIGINS=https://slides.example.com

# 自动登录首个 superuser：1 开 / 0 关（默认跟随 DJANGO_DEBUG）
# EASYSLIDES_AUTO_LOGIN=0

# 幻灯片数据库路径（默认项目根目录 db.sqlite3；TUI 切库也用此变量）
# SLIDES_DB=/path/to/other.sqlite3
